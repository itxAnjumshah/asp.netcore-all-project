@model codefirstapproch.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-5">

    <!-- Center card -->
    <div class="row justify-content-center">

        <div class="col-md-6">

            <!-- Card -->
            <div class="card shadow-lg border-0">

                <!-- Header -->
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">📄 Student Details</h4>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <!-- Details Table -->
                    <table class="table table-bordered">

                        <tr>
                            <th>Name</th>
                            <td>@Model.name</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.email</td>
                        </tr>

                        <tr>
                            <th>Gender</th>
                            <td>@Model.gender</td>
                        </tr>

                        <tr>
                            <th>Date of Birth</th>
                            <td>@Model.Dob</td>
                        </tr>

                        <tr>
                            <th>Age</th>
                            <td>@Model.age</td>
                        </tr>

                    </table>

                    <!-- Buttons -->
                    <div class="d-grid gap-2 mt-3">

                        <!-- Edit Button -->
                        <a asp-action="Edit"
                           asp-route-id="@Model.id"
                           class="btn btn-warning">
                            ✏ Edit Student
                        </a>

                        <!-- Back Button -->
                        <a asp-action="Index"
                           class="btn btn-secondary">
                            ← Back to List
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>