@model codefirstapproch.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-5">

    <!-- Center card -->
    <div class="row justify-content-center">

        <div class="col-md-6">

            <!-- Danger Card -->
            <div class="card shadow-lg border-0">

                <!-- Header -->
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0">⚠ Delete Student Confirmation</h4>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <h5 class="text-center text-danger mb-4">
                        Are you sure you want to delete this student?
                    </h5>

                    <!-- Student Details -->
                    <table class="table table-bordered">

                        <tr>
                            <th>Name</th>
                            <td>@Model.name</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.email</td>
                        </tr>

                        <tr>
                            <th>Gender</th>
                            <td>@Model.gender</td>
                        </tr>

                        <tr>
                            <th>Date of Birth</th>
                            <td>@Model.Dob</td>
                        </tr>

                        <tr>
                            <th>Age</th>
                            <td>@Model.age</td>
                        </tr>

                    </table>

                    <!-- Buttons -->
                    <form asp-action="Delete" class="d-inline">

                        <!-- Hidden ID -->
                        <input type="hidden" asp-for="id" />

                        <!-- Delete Button -->
                        <button type="submit" class="btn btn-danger w-100 mb-2">
                            🗑 Yes, Delete Student
                        </button>

                    </form>

                    <!-- Back Button -->
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        ← Cancel & Back to List
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>